generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECH
  CASHIER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  PENDING
  REPORTED
  PAID
  OVERDUE
  VOID
}

enum ServiceOrderStatus {
  RECEIVED
  DIAGNOSIS
  QUOTE_PENDING
  APPROVED
  IN_REPAIR
  READY_DELIVERY
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
  CREDIT
}

enum InventoryMovementType {
  IN
  PURCHASE
  USE
  ADJUSTMENT
  OUT
}

enum CashMovementType {
  OPEN
  SALE
  EXPENSE
  WITHDRAWAL
  CLOSE
  ADJUSTMENT
}

enum WarrantyStatus {
  ACTIVE
  CLAIMED
  EXPIRED
  VOID
}

model Tenant {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  plan               String               @default("MVP")
  billingEmail       String?
  subscriptionStatus SubscriptionStatus   @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStartsAt DateTime?
  currentPeriodEndsAt DateTime?
  brandProfile       BrandProfile?
  branches           Branch[]
  memberships        Membership[]
  customers          Customer[]
  devices            Device[]
  serviceOrders      ServiceOrder[]
  inventoryItems     InventoryItem[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  payments           Payment[]
  cashSessions       CashSession[]
  posSales           PosSale[]
  warranties         Warranty[]
  auditLogs          AuditLog[]
  subscriptionInvoices SubscriptionInvoice[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model BrandProfile {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName    String?
  logoUrl        String?
  primaryColor   String? @default("#0f62fe")
  secondaryColor String? @default("#101828")
  accentColor    String? @default("#22c55e")
  ticketHeader   String?
  supportEmail   String?
  customDomain   String?
}

model Branch {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  code           String
  address        String?
  phone          String?
  isActive       Boolean         @default(true)
  memberships    Membership[]
  devices        Device[]
  serviceOrders  ServiceOrder[]
  inventoryItems InventoryItem[]
  inventoryMovements InventoryMovement[]
  purchaseOrders PurchaseOrder[]
  payments       Payment[]
  cashSessions   CashSession[]
  posSales       PosSale[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, code])
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  phone        String?
  memberships  Membership[]
  assignedOrders ServiceOrder[]
  auditLogs    AuditLog[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Membership {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  branchId  String?
  role      Role
  status    MembershipStatus @default(ACTIVE)
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([tenantId, userId, branchId])
}

model Customer {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String
  email     String?
  notes     String?
  devices   Device[]
  orders    ServiceOrder[]
  posSales  PosSale[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tenantId, fullName])
  @@index([tenantId, phone])
}

model Device {
  id           String         @id @default(cuid())
  tenantId     String
  branchId     String?
  customerId   String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category     String
  brand        String
  model        String
  serialNumber String?
  imei         String?
  color        String?
  accessories  String?
  issueSummary String?
  orders       ServiceOrder[]
  warranties   Warranty[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId, imei])
  @@index([tenantId, serialNumber])
}

model ServiceOrder {
  id             String             @id @default(cuid())
  tenantId       String
  branchId       String?
  customerId     String
  deviceId       String
  assignedUserId String?
  folio          String
  status         ServiceOrderStatus @default(RECEIVED)
  priority       String?
  failureReport  String
  diagnosis      String?
  intakeNotes    String?
  promisedAt     DateTime?
  estimateAmount Decimal?           @db.Decimal(10, 2)
  paidAmount     Decimal            @default(0) @db.Decimal(10, 2)
  balanceAmount  Decimal            @default(0) @db.Decimal(10, 2)
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  device         Device             @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  assignedUser   User?              @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  notes          ServiceOrderNote[]
  partsUsed      ServiceOrderPart[]
  payments       Payment[]
  warranty       Warranty?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([tenantId, folio])
  @@index([tenantId, status])
}

model ServiceOrderNote {
  id             String       @id @default(cuid())
  serviceOrderId String
  type           String       @default("timeline")
  content        String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model ServiceOrderPart {
  id              String        @id @default(cuid())
  serviceOrderId  String
  inventoryItemId String
  quantity        Int
  unitCost        Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  serviceOrder    ServiceOrder  @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id             String              @id @default(cuid())
  tenantId       String
  branchId       String?
  supplierId     String?
  sku            String
  name           String
  category       String
  description    String?
  stock          Int                 @default(0)
  minStock       Int                 @default(1)
  unitCost       Decimal             @db.Decimal(10, 2)
  salePrice      Decimal             @db.Decimal(10, 2)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplier       Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements      InventoryMovement[]
  partsUsed      ServiceOrderPart[]
  posSaleItems   PosSaleItem[]
  purchaseItems  PurchaseOrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([tenantId, sku])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  inventoryItemId String
  branchId        String?
  type            InventoryMovementType
  quantity        Int
  reference       String?
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  branch          Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
}

model Supplier {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  notes          String?
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  tenantId       String
  branchId       String?
  supplierId     String
  folio          String
  status         String              @default("draft")
  subtotal       Decimal             @default(0) @db.Decimal(10, 2)
  tax            Decimal             @default(0) @db.Decimal(10, 2)
  total          Decimal             @default(0) @db.Decimal(10, 2)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items          PurchaseOrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([tenantId, folio])
}

model PurchaseOrderItem {
  id              String         @id @default(cuid())
  purchaseOrderId String
  inventoryItemId String?
  description     String
  quantity        Int
  unitCost        Decimal        @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
}

model Payment {
  id             String        @id @default(cuid())
  tenantId       String
  branchId       String?
  serviceOrderId String?
  posSaleId      String?
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  note           String?
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  posSale        PosSale?      @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  receivedAt     DateTime      @default(now())
}

model CashSession {
  id             String         @id @default(cuid())
  tenantId       String
  branchId       String?
  openedByUserId String?
  closedByUserId String?
  openingAmount  Decimal        @db.Decimal(10, 2)
  closingAmount  Decimal?       @db.Decimal(10, 2)
  expectedAmount Decimal?       @db.Decimal(10, 2)
  status         String         @default("open")
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  movements      CashMovement[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  type          CashMovementType
  amount        Decimal          @db.Decimal(10, 2)
  note          String?
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
}

model PosSale {
  id         String        @id @default(cuid())
  tenantId   String
  branchId   String?
  customerId String?
  folio      String
  subtotal   Decimal       @db.Decimal(10, 2)
  tax        Decimal       @default(0) @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      PosSaleItem[]
  payments   Payment[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([tenantId, folio])
}

model PosSaleItem {
  id              String         @id @default(cuid())
  posSaleId       String
  inventoryItemId String?
  description     String
  quantity        Int
  unitPrice       Decimal        @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  posSale         PosSale        @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
}

model Warranty {
  id             String         @id @default(cuid())
  tenantId       String
  serviceOrderId String         @unique
  deviceId       String
  status         WarrantyStatus @default(ACTIVE)
  startsAt       DateTime
  endsAt         DateTime
  terms          String?
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder   ServiceOrder   @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  device         Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  entityType String
  entityId   String
  action     String
  metadata   Json?
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model SubscriptionInvoice {
  id          String                    @id @default(cuid())
  tenantId    String
  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planName    String
  status      SubscriptionInvoiceStatus @default(PENDING)
  amount      Decimal                   @db.Decimal(10, 2)
  currency    String                    @default("MXN")
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  paidAt      DateTime?
  externalRef String?
  notes       String?
  paymentReportedAt DateTime?
  paymentReference  String?
  paymentReporterName String?
  paymentReporterEmail String?
  paymentNotes String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
}
